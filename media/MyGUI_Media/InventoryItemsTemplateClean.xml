<?xml version="1.0" encoding="UTF-8"?>
<!--
===========================================================================
  InventoryItems.png  —  814 x 384 px
===========================================================================

  ITEM ICON GRID  (74x74 px per cell, border included, step=74)

  +--------+--------+--------+--------+--------+--------+--------+--------+--------+
  |        | Item 0 | Item 1 | Item 2 | Item 3 | Item 4 | Item 5 | Item 6 | Item 7 | Item 8
  |        | x=0    | x=74   | x=148  | x=222  | x=296  | x=370  | x=444  | x=518  | x=592
  +--------+--------+--------+--------+--------+--------+--------+--------+--------+
  | y=0    | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon
  | Normal |        |        |        |        |        |        |        |        |
  +--------+--------+--------+--------+--------+--------+--------+--------+--------+
  | y=74   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon
  | Refuse |        |        |        |        |        |        |        |        |
  +--------+--------+--------+--------+--------+--------+--------+--------+--------+
  | y=148  | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon   | Icon
  | Accept |        |        |        |        |        |        |        |        |
  +--------+--------+--------+--------+--------+--------+--------+--------+--------+
  | y=222  | (only BackImage Select state used here, items leave this row empty)   |
  +--------+--------+--------+--------+--------+--------+--------+--------+--------+

  TOOLTIP ROW  (32x32 px per cell, step=32)  y=352
  +------+------+------+------+------+------+------+------+------+
  | TT 0 | TT 1 | TT 2 | TT 3 | TT 4 | TT 5 | TT 6 | TT 7 | TT 8 ...
  | x=0  | x=32 | x=64 | x=96 |x=128 |x=160 |x=192 |x=224 |x=256
  +------+------+------+------+------+------+------+------+------+

  BACKIMAGE  (cell background)  x=666, size=74x74
    y=0   — None / Normal  (default cell)
    y=74  — Active         (mouse hover)
    y=148 — Pressed        (mouse button down)
    y=222 — Select         (cell selected)

  SELECTIMAGE  (drag-and-drop border overlay)  x=740, size=74x74
    y=0   — Normal  (drag active, neutral border)
    y=74  — Refuse  (drop not allowed, red border)
    y=148 — Accept  (drop allowed, green border)
    y=222 — None    (invisible, no drag)

===========================================================================
-->
<MyGUI type="Resource">

    <!-- ==================================================================
         CELL BACKGROUND  —  pic_ItemBackImage
         Texture: InventoryItems.png  |  Cell size: 74x74
         ================================================================== -->
    <Resource type="ResourceImageSet" name="pic_ItemBackImage">
        <Group name="States" texture="InventoryItems.png" size="74 74">
            <Index name="None">
                <Frame point="666 0"/>   <!-- x=666 y=0   — default, no interaction -->
            </Index>
            <Index name="Normal">
                <Frame point="666 0"/>   <!-- x=666 y=0   — default -->
            </Index>
            <Index name="Active">
                <Frame point="666 74"/>  <!-- x=666 y=74  — mouse hover -->
            </Index>
            <Index name="Pressed">
                <Frame point="666 148"/> <!-- x=666 y=148 — mouse button down -->
            </Index>
            <Index name="Select">
                <Frame point="666 222"/> <!-- x=666 y=222 — cell selected -->
            </Index>
        </Group>
    </Resource>

    <!-- ==================================================================
         DRAG-AND-DROP BORDER  —  pic_ItemSelectImage
         Texture: InventoryItems.png  |  Cell size: 74x74
         ================================================================== -->
    <Resource type="ResourceImageSet" name="pic_ItemSelectImage">
        <Group name="States" texture="InventoryItems.png" size="74 74">
            <Index name="None">
                <Frame point="740 222"/> <!-- x=740 y=222 — invisible, no drag -->
            </Index>
            <Index name="Normal">
                <Frame point="740 0"/>   <!-- x=740 y=0   — drag active, neutral border -->
            </Index>
            <Index name="Refuse">
                <Frame point="740 74"/>  <!-- x=740 y=74  — drop not allowed, red border -->
            </Index>
            <Index name="Accept">
                <Frame point="740 148"/> <!-- x=740 y=148 — drop allowed, green border -->
            </Index>
        </Group>
    </Resource>

    <!-- ==================================================================
         ITEM DEFINITIONS
         To add a new item: copy one block, change name and RefID.
         ================================================================== -->

    <Resource type="ResourceItemInfo" name="Item0">
        <Name>Item 0</Name>
        <Description>Description of item 0.</Description>
        <Image RefID="pic_Item0"/>
    </Resource>

    <Resource type="ResourceItemInfo" name="Item1">
        <Name>Item 1</Name>
        <Description>Description of item 1.</Description>
        <Image RefID="pic_Item1"/>
    </Resource>

    <Resource type="ResourceItemInfo" name="Item2">
        <Name>Item 2</Name>
        <Description>Description of item 2.</Description>
        <Image RefID="pic_Item2"/>
    </Resource>

    <Resource type="ResourceItemInfo" name="Item3">
        <Name>Item 3</Name>
        <Description>Description of item 3.</Description>
        <Image RefID="pic_Item3"/>
    </Resource>

    <Resource type="ResourceItemInfo" name="Item4">
        <Name>Item 4</Name>
        <Description>Description of item 4.</Description>
        <Image RefID="pic_Item4"/>
    </Resource>

    <Resource type="ResourceItemInfo" name="Item5">
        <Name>Item 5</Name>
        <Description>Description of item 5.</Description>
