    </Resource>

    <Resource type="ResourceItemInfo" name="Item8">
        <Name>Item 8</Name>
        <Description>Description of item 8.</Description>
        <Image RefID="pic_Item8"/>
    </Resource>

    <!-- ==================================================================
         IMAGE RESOURCES  —  sprite sheet coordinates
         States group:  74x74,  3 rows  (Normal y=0 / Refuse y=74 / Accept y=148)
         ToolTip group: 32x32,  y=352
         ================================================================== -->

