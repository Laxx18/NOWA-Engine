{
    "comment" :
    [
        "PlanetOcean default PBS material.",
        "specular_fresnel workflow: physically correct for water.",
        "Fresnel 0.02 = real water at normal incidence (rises to 1.0 at grazing via Schlick).",
        "Keep metalness at 0 -- water is dielectric.",
        "Detail normal map slot 0 is used for tiled wave surface detail (set programmatically).",
        "Roughness 0.25: broad specular highlights visible from space + surface."
    ],

    "macroblocks" :
    {
        "Ocean_Macroblock" :
        {
            "scissor_test"           : false,
            "depth_check"            : true,
            "depth_write"            : true,
            "depth_function"         : "less_equal",
            "depth_bias_constant"    : 0,
            "depth_bias_slope_scale" : 0,
            "cull_mode"              : "none",
            "polygon_mode"           : "solid"
        }
    },

    "blendblocks" :
    {
        "Ocean_Blendblock_Opaque" :
        {
            "alpha_to_coverage"       : false,
            "blendmask"               : "rgba",
            "separate_blend"          : false,
            "src_blend_factor"        : "one",
            "dst_blend_factor"        : "zero",
            "blend_operation"         : "add",
            "force_transparent_sort"  : false
        }
    },

    "pbs" :
    {
        "PlanetOceanDefaultMaterial" :
        {
            "macroblock"        : "Ocean_Macroblock",
            "blendblock"        : "Ocean_Blendblock_Opaque",
            "shadow_const_bias" : 0.001,

            "workflow" : "specular_fresnel",
            "brdf"     : "default",

            "roughness" : 0.25,

            "fresnel" :
            {
                "value" : 0.035,
                "mode"  : "coeff"
            },

            "specular" :
            {
                "value" : [1.0, 1.0, 1.0]
            },

            "diffuse" :
            {
                "value" : [0.0, 0.012, 0.035]
            }
        }
    }
}